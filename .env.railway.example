APP_NAME=Horas Complementares Bot
DATABASE_URL=postgresql+psycopg://USUARIO:SENHA@HOST:PORTA/BANCO
STORAGE_DIR=/data/storage
STORAGE_BACKEND=s3
STORAGE_BUCKET=horas-complementares
STORAGE_REGION=auto
STORAGE_ENDPOINT_URL=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=SUA_ACCESS_KEY
STORAGE_SECRET_ACCESS_KEY=SUA_SECRET_KEY
STORAGE_KEY_PREFIX=evidences
TELEGRAM_BOT_TOKEN=SEU_TOKEN_DO_BOTFATHER
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_MODE=webhook
TELEGRAM_WEBHOOK_URL=https://seu-servico.up.railway.app/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=um_token_simples_123
TELEGRAM_AUTO_SET_WEBHOOK=true
TELEGRAM_POLLING_TIMEOUT_SECONDS=25
TELEGRAM_POLLING_SLEEP_SECONDS=1
MAX_UPLOAD_SIZE_MB=10
MAX_EVIDENCES_PER_SUBMISSION=3
MAX_DOCUMENTS_PER_USER_PER_HOUR=12
MAX_DOCUMENTS_PER_USER_PER_DAY=30
INCOMING_DOCUMENT_RETENTION_DAYS=14
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png
